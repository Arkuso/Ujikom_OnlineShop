# =========================
# Environment
# =========================
# Set to Development for local, Production for live server
ASPNETCORE_ENVIRONMENT=Development

# =========================
# Backend (.NET) - Database
# =========================
# SQL Server Connection String
# Local example (Windows Auth):
#   Server=LAPTOP_NAME\SQLEXPRESS;Database=OnlineShopDb;Trusted_Connection=True;TrustServerCertificate=True
# SQL Auth example:
#   Server=localhost,1433;Database=OnlineShopDb;User Id=sa;Password=YourPassword;TrustServerCertificate=True
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=OnlineShopDb;Trusted_Connection=True;TrustServerCertificate=True

# =========================
# Backend (.NET) - Authentication & Security
# =========================
# JWT secret (required, minimum 64 characters)
AppSettings__Token=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_MIN_64_CHARS

# Internal key for protected admin promotion endpoint
InternalSecurity__PromoteAdminKey=CHANGE_THIS_INTERNAL_KEY

# =========================
# Backend (.NET) - Logging (Optional)
# =========================
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning

# =========================
# Frontend (Next.js)
# =========================
# API base URL used by frontend service layer
NEXT_PUBLIC_API_BASE_URL=http://localhost:5055

# Optional frontend app metadata
# NEXT_PUBLIC_APP_NAME=OnlineShop
