# ============================================================
# .env.example — OnlineShop Ujikom Project
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# JANGAN pernah commit file .env asli ke Git!
# ============================================================


# ============================================================
# 1. ENVIRONMENT
# ============================================================
# Gunakan "Development" untuk lokal, "Production" untuk server live
ASPNETCORE_ENVIRONMENT=Development


# ============================================================
# 2. DATABASE (Backend .NET)
# ============================================================
# Format Windows Authentication (tanpa password, untuk lokal):
#   Server=NAMA_LAPTOP\SQLEXPRESS;Database=OnlineShopDb;Trusted_Connection=True;TrustServerCertificate=True
# Format SQL Server Authentication (dengan username & password):
#   Server=localhost,1433;Database=OnlineShopDb;User Id=sa;Password=YourPassword;TrustServerCertificate=True

ConnectionStrings__DefaultConnection=Server=YOUR_SERVER_NAME\SQLEXPRESS;Database=OnlineShopDb;Trusted_Connection=True;TrustServerCertificate=True


# ============================================================
# 3. AUTENTIKASI JWT (Backend .NET)
# ============================================================
# Kunci rahasia untuk menandatangani token JWT.
# WAJIB minimal 64 karakter. Gunakan generator password acak.
AppSettings__Token=GANTI_DENGAN_KUNCI_RAHASIA_MINIMAL_64_KARAKTER_CONTOH_1234567890ABCDEF


# ============================================================
# 4. KEAMANAN INTERNAL
# ============================================================
# Kunci rahasia untuk endpoint promote-admin (hanya untuk developer).
# Gunakan string acak yang kuat.
InternalSecurity__PromoteAdminKey=GANTI_DENGAN_KUNCI_INTERNAL_YANG_KUAT


# ============================================================
# 5. XENDIT PAYMENT GATEWAY (Backend .NET)
# ============================================================
# Dapatkan dari: https://dashboard.xendit.co/settings/developers
#
# Secret Key: Digunakan untuk membuat Invoice via API Xendit.
#   Format mode test : xnd_development_XXXXXXXXXXXXXXXXXXXX
#   Format mode live : xnd_production_XXXXXXXXXXXXXXXXXXXX
Xendit__SecretKey=xnd_development_MASUKKAN_SECRET_KEY_XENDIT_ANDA

# Callback Token: Digunakan untuk memverifikasi bahwa Webhook
#   yang masuk benar-benar dikirim oleh Xendit (bukan pihak lain).
#   Dapatkan dari: Xendit Dashboard → Settings → Callbacks → Callback Token
Xendit__CallbackToken=MASUKKAN_CALLBACK_TOKEN_XENDIT_ANDA

# Webhook URL: URL publik yang didaftarkan ke Xendit untuk menerima notifikasi.
#   Untuk lokal, gunakan ngrok: https://xxxx.ngrok-free.app/api/webhooks/xendit
#   Untuk production: https://domain-anda.com/api/webhooks/xendit
Xendit__WebhookUrl=https://URL_NGROK_ATAU_DOMAIN_ANDA/api/webhooks/xendit


# ============================================================
# 6. URL FRONTEND (Backend .NET — untuk Redirect Xendit)
# ============================================================
# URL dasar Frontend. Digunakan sebagai redirect setelah pembayaran Xendit berhasil/gagal.
# Lokal: http://localhost:3000
# Production: https://domain-toko-anda.com
FrontendBaseUrl=http://localhost:3000


# ============================================================
# 7. FRONTEND (Next.js)
# ============================================================
# URL dasar Backend API yang digunakan oleh service layer di Frontend.
# Pastikan cocok dengan port yang dijalankan oleh `dotnet run`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5055
